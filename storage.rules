rules_version = '2';
// Tata.Manager — Storage Rules (Fase 1)
// Requiere membresía en Firestore: tenants/{tenantId}/members/{uid}
// Deploy: firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isMember(tenantId) {
      return signedIn()
        && firestore.exists(
          /databases/(default)/documents/tenants/$(tenantId)/members/$(request.auth.uid)
        )
        && firestore.get(
          /databases/(default)/documents/tenants/$(tenantId)/members/$(request.auth.uid)
        ).data.activo == true;
    }

    match /tenants/{tenantId}/{allPaths=**} {
      allow read: if isMember(tenantId);
      allow write: if isMember(tenantId)
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf|application/octet-stream');
    }
  }
}
