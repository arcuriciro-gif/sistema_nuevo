rules_version = '2';
// OBLIGATORIO: Firebase Console → Build → Storage → Rules → pegar esto → Publish
// (o: firebase deploy --only storage)
// Sin Storage habilitado + estas reglas, las fotos fallan con object-not-found /
// permission-denied. Firestore (costos/stock) puede seguir funcionando igual.
service firebase.storage {
  match /b/{bucket}/o {
    match /tenants/{tenantId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024;
    }
  }
}
